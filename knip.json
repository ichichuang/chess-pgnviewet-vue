{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["index.html", "src/router/index.ts", "src/ui/index.ts", "src/types/index.ts"],
  "project": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "*.config.{js,mjs,cjs,ts}",
    "scripts/governance/**/*.mjs"
  ],
  "rules": {
