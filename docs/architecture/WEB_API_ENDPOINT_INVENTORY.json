{
    "schemaVersion": 3,
    "status": "ACTIVE_AUTHORITY",
    "effectiveDate": "2026-07-14",
    "sourceAuthorities": [
        {
            "id": "pgnViewer",
            "root": "/Users/cc/Work/neobv/Chess/pgnViewer",
            "mode": "READ_ONLY"
        },
        {
            "id": "chess-main-overseas",
            "root": "/Users/cc/Work/neobv/Chess/chess-main-overseas",
            "mode": "READ_ONLY"
        }
    ],
    "origin": {
        "id": "chessApi",
        "value": "https://wxapi.kaisaile.org",
        "runtimeConfigurable": false,
        "browserCrossOrigin": "LOCALHOST_USES_FIXED_DEVELOPMENT_PROXY_PRODUCTION_USES_DIRECT_HTTPS"
    },
    "confirmedPublicReads": [
        {
            "id": "tournament.list",
            "method": "POST",
            "path": "/liveproxy/GetActList",
            "requestFields": ["actflag", "max", "month", "search", "start", "type", "year"],
            "responseEnvelope": ["resp", "content.Total", "content.Details"],
            "responseItemFields": [
                "act_endtime",
                "act_sign",
                "act_starttime",
                "actflag",
                "delaymatchtime",
                "ext_catgory",
                "hdid",
                "poster",
                "sign_endtime",
                "sponsor",
                "sponsorLogo",
                "title"
            ],
            "pagination": "start-max",
            "liveProbe": "CONFIRMED_NO_CREDENTIAL"
        },
        {
            "id": "tournament.detail",
            "method": "POST",
            "path": "/award/c-GetActDetail?token=&type=10",
            "fixedEmptyQueryParameter": true,
            "requestFields": ["id", "sid"],
            "responseEnvelope": ["resp", "content"],
            "responseFields": [
                "act_addr",
                "act_endtime",
                "act_starttime",
                "description",
                "ext_catgory",
                "id",
                "isfinish",
                "shoptitle",
                "sponsor",
                "state",
                "title",
                "type"
            ],
            "liveProbe": "CONFIRMED_NO_CREDENTIAL"
        },
        {
            "id": "tournament.groups",
            "method": "POST",
            "path": "/liveproxy/GetActGroups",
            "requestFields": ["hdid"],
            "responseEnvelope": ["resp", "content"],
            "responseItemFields": ["cur_state", "hdid", "signcount", "ticketid", "ticketname"],
            "liveProbe": "CONFIRMED_NO_CREDENTIAL"
        },
        {
            "id": "tournament.rounds",
            "method": "POST",
            "path": "/award/c-GetMatchRoundlist",
            "requestFields": ["hdid", "ticketid"],
            "responseEnvelope": [
                "resp",
                "content.cur_round",
                "content.roundfinish",
                "content.roundinfo"
            ],
            "responseItemFields": ["round_id", "starttime"],
            "liveProbe": "CONFIRMED_NO_CREDENTIAL"
        },
        {
            "id": "tournament.pairings",
            "method": "POST",
            "path": "/award/c-GetMatchPairlist",
            "requestFields": ["hdid", "name", "plen", "round_id", "st", "ticketid", "type"],
            "responseEnvelope": ["resp", "content"],
            "responseItemFields": [
                "belo",
                "bfaceimg",
                "bfieldid",
                "bjgname",
                "black",
                "blackname",
                "id",
                "sort_id",
                "status",
                "welo",
                "wfaceimg",
                "wfieldid",
                "white",
                "whitename",
                "wjgname"
            ],
            "pagination": "st-plen",
            "liveProbe": "CONFIRMED_NO_CREDENTIAL"
        }
    ],
    "confirmedAuthentication": {
        "repository": "authRepository",
        "passwordTransformation": "LOWERCASE_HEXADECIMAL_MD5_DURING_SUBMISSION",
        "browserSigning": "CENTRALIZED_TRACKED_HMAC_COMPATIBILITY_ADAPTER",
        "login": {
            "method": "POST",
            "path": "/liveproxy/PostLoginByPhone",
            "requestFields": ["Type", "code", "login_func", "mobile", "pwd", "tel", "type"],
            "responseEnvelope": ["resp.msg", "content.token", "content.uid"]
        },
        "identity": [
            {
                "method": "POST",
                "path": "/ucenter/GetUserDetail",
                "requestFields": ["showall", "token", "uid"],
                "responseEnvelope": ["content.uid", "content.mobile"]
            },
            {
                "method": "POST",
                "path": "/ucenter/GetUserCenterInfo",
                "requestFields": ["token"],
                "responseEnvelope": ["content.nickname", "content.explain", "content.mpurl"]
            }
        ],
        "persistenceSeconds": 43200,
        "logout": "LOCAL_ONLY",
        "http401": "CLEAR_AUTH_AND_PRIVATE_STATE",
        "http403": "PRESERVE_AUTH_AND_REPORT_PERMISSION_DENIAL"
    },
    "displayComposition": {
        "route": "/competitions/:hdid/display",
        "repository": "competitionDisplayRepository",
        "reads": [
            "tournament.detail",
            "tournament.groups",
            "tournament.rounds",
            "tournament.pairings"
        ],
        "independentEndpoint": false
    },
