{
  "name": "chess-pgnviewer-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "26.5.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck:vue && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm run typecheck:vue",
    "typecheck:vue": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:style": "stylelint \"src/**/*.{css,vue}\"",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "check:deps": "node scripts/governance/check-dependency-policy.mjs",
    "check:architecture": "node scripts/governance/check-architecture-boundaries.mjs",
    "check:tokens": "node scripts/governance/check-raw-visual-values.mjs",
    "check:mocks": "node scripts/governance/check-forbidden-mock-data.mjs",
    "check:secrets": "node scripts/governance/check-secret-patterns.mjs",
    "check:governance": "run-s check:deps check:architecture check:tokens check:mocks check:secrets",
    "check:unused": "knip --no-progress",
    "audit:prod": "pnpm audit --prod",
    "check:static": "run-s lint lint:style format:check check:governance check:unused audit:prod"
  },
  "dependencies": {
    "@tanstack/vue-query": "5.101.2",
    "axios": "1.18.1",
    "chess.js": "1.4.0",
    "dexie": "4.4.4",
    "gsap": "3.15.0",
    "naive-ui": "2.44.1",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "knip": "6.26.0",
    "npm-run-all2": "9.0.2",
    "postcss-html": "1.8.1",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.7"
  }
}
